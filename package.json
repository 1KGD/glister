{
    "name": "glister",
    "version": "1.0.0",
    "description": "A browser-based spaceship game",
    "main": "index.js",
    "scripts": {
        "dev": "concurrently --kill-others --names vite,colyseus -c green,blue 'pnpm run client-dev' 'pnpm run server-dev'",
        "client-dev": "vite",
        "server-dev": "tsx watch --clear-screen=false src/server/index.ts",
        "build-client": "vite build",
        "build-server": "rollup -c"
    },
    "keywords": [],
    "author": "",
    "license": "MIT",
    "devEngines": {
        "packageManager": {
            "name": "pnpm",
            "version": "^11.0.9",
            "onFail": "download"
        }
    },
    "type": "module",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@rollup/plugin-commonjs": "^29.0.3",
        "@rollup/plugin-json": "^6.1.0",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-terser": "^1.0.0",
        "@rollup/plugin-typescript": "^12.3.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/react": "^19.2.15",
        "@types/react-dom": "^19.2.3",
        "@types/three": "^0.184.1",
        "concurrently": "^9.2.1",
        "eslint": "^10.4.1",
        "rollup": "^4.61.0",
        "tslib": "^2.8.1",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.0",
        "vite": "^8.0.16",
        "vite-preload": "^1.0.5"
    },
    "dependencies": {
        "@colyseus/react": "^0.1.15",
        "@colyseus/schema": "^4.0.26",
        "@colyseus/sdk": "^0.17.42",
        "@react-three/drei": "^10.7.7",
        "better-sqlite3": "^12.10.0",
        "colyseus": "^0.17.10",
        "cookie-parser": "^1.4.7",
        "konva": "^10.3.0",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-konva": "^19.2.4",
        "react-router": "^7.16.0",
        "reflect-metadata": "^0.2.2",
        "tesseract": "link:tesseract",
        "three": "^0.184.0",
        "three.quarks": "^0.17.1",
        "typeorm": "^1.0.0",
        "uuid": "^14.0.0"
    }
}
